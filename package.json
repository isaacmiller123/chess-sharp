{
  "name": "chess-sharp",
  "version": "1.1.5",
  "description": "Chess# — offline, local-first chess analysis & teaching desktop app powered by Stockfish, with bundled Lichess content and local coaching.",
  "author": "Isaac Miller",
  "license": "GPL-3.0-or-later",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "postinstall": "node scripts/patch-ffish-csp.mjs",
    "smoke:packed-wasm": "node scripts/smoke-packed-wasm.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "setup:engines": "node scripts/run-python.mjs scripts/fetch_engines.py",
    "setup:puzzles": "node scripts/fetch-puzzles.mjs",
    "build:puzzles": "node scripts/run-python.mjs scripts/build_puzzles_db.py",
    "build:openings": "node scripts/build-openings.mjs",
    "build:famous": "node scripts/build-famous.mjs",
    "build:personas": "node scripts/build-persona-data.mjs",
    "fetch:persona-photos": "node scripts/fetch-persona-photos.mjs",
    "smoke:engine": "node scripts/smoke_engine.mjs",
    "test:ratings": "node scripts/test-ratings-integrity.mjs",
    "test:school-replace": "node scripts/test-school-replace.mjs",
    "setup": "npm run setup:engines && npm run setup:puzzles && npm run build:puzzles && npm run build:openings",
    "dist:exe": "electron-vite build && electron-builder --dir",
    "package": "electron-vite build && electron-builder",
    "art:chess3d": "node scripts/prep-chess3d.mjs",
    "smoke:chess3d": "node scripts/smoke-chess3d.mjs"
  },
  "dependencies": {
    "@jortvl/draughts": "^0.4.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sabaki/shudan": "^1.7.1",
    "chessground": "^9.2.1",
    "chessgroundx": "^10.7.5",
    "chessops": "^0.15.0",
    "ffish-es6": "^0.7.9",
    "lucide-react": "^1.21.0",
    "preact": "^10.29.4",
    "rapid-draughts": "^1.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tenuki": "^0.3.1",
    "three": "^0.185.1",
    "trystero": "^0.25.2",
    "ts-fsrs": "^5.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  }
}
