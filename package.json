{
  "name": "chess-sharp",
  "version": "1.2.1",
  "description": "Chess# — offline, local-first chess analysis & teaching desktop app powered by Stockfish, with bundled Lichess content and local coaching.",
  "author": "Isaac Miller",
  "license": "GPL-3.0-or-later",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "postinstall": "node scripts/patch-ffish-csp.mjs",
    "smoke:packed-wasm": "node scripts/smoke-packed-wasm.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web && npm run typecheck:server",
    "dev:web": "vite --config vite.web.config.ts",
    "build:web": "vite build --config vite.web.config.ts",
    "build:server": "node scripts/build-server.mjs && node scripts/build-ipc-bridge.mjs",
    "serve:web": "node dist-server/index.cjs",
    "start:web": "npm run build:web && npm run build:server && npm run serve:web",
    "test:db-seam": "node scripts/test-db-seam.mjs",
    "test:web-stub": "node scripts/test-web-stub.mjs",
    "test:web-server": "node scripts/test-web-server.mjs",
    "test:web-engines": "node scripts/test-web-engines.mjs",
    "test:web-auth": "node scripts/test-web-auth.mjs",
    "test:web-bridge": "node scripts/test-web-bridge.mjs",
    "test:web-client": "node scripts/test-web-client.mjs",
    "test:accounts-core": "node scripts/test-accounts-core.mjs",
    "test:accounts-chain": "node scripts/test-accounts-chain.mjs",
    "test:web-accounts": "node scripts/test-web-accounts.mjs",
    "test:web-accounts-browser": "node scripts/test-web-accounts-browser.mjs",
    "setup:engines": "node scripts/run-python.mjs scripts/fetch_engines.py",
    "setup:puzzles": "node scripts/fetch-puzzles.mjs",
    "build:puzzles": "node scripts/run-python.mjs scripts/build_puzzles_db.py",
    "build:openings": "node scripts/build-openings.mjs",
    "build:famous": "node scripts/build-famous.mjs",
    "build:personas": "node scripts/build-persona-data.mjs",
    "fetch:persona-photos": "node scripts/fetch-persona-photos.mjs",
    "smoke:engine": "node scripts/smoke_engine.mjs",
    "test:ratings": "node scripts/test-ratings-integrity.mjs",
    "test:school-replace": "node scripts/test-school-replace.mjs",
    "test:theater": "node scripts/test-theater.mjs",
    "test:updater": "node scripts/test-updater.mjs",
    "setup": "npm run setup:engines && npm run setup:puzzles && npm run build:puzzles && npm run build:openings",
    "dist:exe": "electron-vite build && electron-builder --dir",
    "package": "electron-vite build && electron-builder",
    "art:chess3d": "node scripts/prep-chess3d.mjs",
    "smoke:chess3d": "node scripts/smoke-chess3d.mjs"
  },
  "dependencies": {
    "@jortvl/draughts": "^0.4.2",
    "@noble/ed25519": "3.1.0",
    "@noble/hashes": "2.2.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sabaki/shudan": "^1.7.1",
    "@scure/base": "2.2.0",
    "@scure/bip39": "2.2.0",
    "chessground": "^9.2.1",
    "chessgroundx": "^10.7.5",
    "chessops": "^0.15.0",
    "electron-updater": "^6.8.9",
    "ffish-es6": "^0.7.9",
    "hash-wasm": "4.12.0",
    "lucide-react": "^1.21.0",
    "preact": "^10.29.4",
    "rapid-draughts": "^1.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tenuki": "^0.3.1",
    "three": "^0.185.1",
    "trystero": "^0.25.2",
    "ts-fsrs": "^5.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@fastify/cookie": "^11.1.1",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^9.3.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "fairy-stockfish-nnue.wasm": "^1.1.11",
    "fastify": "^5.10.0",
    "lila-stockfish-web": "^0.0.11",
    "playwright-core": "1.61.1",
    "stockfish": "^18.0.8",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vite-plugin-static-copy": "^4.1.1"
  }
}
