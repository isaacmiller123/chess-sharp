# ---- Dependencies ----
node_modules/
.pnp/
.pnp.js

# ---- Build output ----
dist/
dist-electron/
out/
build/
release/
*.tsbuildinfo

# ---- Electron packaging artifacts ----
*.exe
*.nsis
*.dmg
*.AppImage
*.deb
*.snap
*.blockmap

# ---- Local app/user data (kept INSIDE the project during dev, never committed) ----
/.devdata/
/.userdata/
/.appdata/
/.cache/

# ---- Raw downloads & temp (fetched/built by setup scripts) ----
/data/raw/
/data/tmp/
*.zst
*.zip

# ---- Engine binaries, NNUE nets & neural weights (fetched by scripts; NEVER committed) ----
/resources/engine/**/*.exe
/resources/engine/**/*.dll
/resources/engine/stockfish*
/resources/engine/*.nnue
/resources/engine/**/*.nnue
/resources/engine/weights/
*.pb.gz
# GPL/AGPL corresponding-source tarballs are fetched at setup and bundled at package time
/resources/licenses/*-src-*.tar*
/resources/licenses/*-src-*.zip

# ---- Generated databases (built from raw datasets by ingest scripts) ----
/resources/data/*.sqlite
/resources/data/*.db
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# ---- Logs & env ----
*.log
npm-debug.log*
yarn-error.log*
.env
.env.local
.env.*.local

# ---- Stray agent/tool scratch dumps in repo root (never commit) ----
/_*.json

# ---- Editor / OS junk ----
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.DS_Store
Thumbs.db
desktop.ini
