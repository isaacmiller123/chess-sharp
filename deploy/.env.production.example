# Chess# production deploy — copy to deploy/.env.production and fill in.
# Consumed by deploy/docker-compose.prod.yml (`cd deploy && docker compose --env-file .env.production -f docker-compose.prod.yml up --build -d`).

# ── Your domain (one apex you control DNS for) ───────────────────────────────
# You will point three A records at this server's public IP:
#   app.DOMAIN    → the web app
#   relay.DOMAIN  → the Nostr signaling relay (wss)
#   turn.DOMAIN   → coturn (TURN); can also be a bare A record to the same IP
DOMAIN=example.com

# Email for Let's Encrypt (Caddy uses it for cert issuance notices).
ACME_EMAIL=you@example.com

# ── This server's PUBLIC IP (required by coturn for relay candidates) ─────────
# The literal public IPv4 of the VPS. `curl -4 ifconfig.co` on the box.
EXTERNAL_IP=203.0.113.10

# ── TURN credential (long-term cred; baked into the app via VITE_ICE_SERVERS) ─
# Any strong random string. The username is fixed as "chess".
TURN_PASSWORD=change-me-to-a-long-random-secret

# ── BUILD-TIME app config (vite inlines these into the SPA at docker build) ───
# These MUST agree with the coturn + relay you deploy below.
#   VITE_ICE_SERVERS : JSON RTCIceServer[] — OUR TURN + public STUN fallback.
#   VITE_NOSTR_RELAYS: comma list of OUR wss relays.
# Defaults below assume DOMAIN=example.com + TURN_PASSWORD above — EDIT to match.
VITE_ICE_SERVERS=[{"urls":["turn:turn.example.com:3478","turn:turn.example.com:3478?transport=tcp","turns:turn.example.com:5349"],"username":"chess","credential":"change-me-to-a-long-random-secret"},{"urls":["stun:turn.example.com:3478","stun:stun.l.google.com:19302"]}]
VITE_NOSTR_RELAYS=wss://relay.example.com

# ── Reverse proxy trusts X-Forwarded-* (Caddy terminates TLS) ────────────────
TRUST_PROXY=1
